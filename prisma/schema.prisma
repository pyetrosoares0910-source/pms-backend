generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UnitBase {
  ML
  G
  UNIT
}

model Stay {
  id               String                      @id @default(uuid())
  name             String
  createdAt        DateTime                    @default(now())
  position         Int?
  maintenanceTasks MaintenanceTask[]
  operationalReminders OperationalReminder[]
  rooms            Room[]
  inventories      Inventory[]
  purchases        Purchase[]
  profiles         ConsumptionProfile[]
  events           ConsumptionEvent[]
  dailyCommon      DailyCommonConsumptionLog[]
  productEntries   ProductEntry[]
  productLots      ProductLot[]
  productConsumptions ProductConsumption[]
  productAlerts    ProductAlert[]
  productPredictions ProductPrediction[]
  inventorySnapshots ProductInventorySnapshot[]
  productUsageCycles ProductUsageCycle[]
  laundryDispatches LaundryDispatch[]

  @@unique([name])
}

model Room {
  id               String               @id @default(uuid())
  active           Boolean              @default(true)
  selfCheckinEnabled Boolean            @default(true)
  stayId           String?
  description      String?
  title            String
  capacity         Int?
  imageUrl         String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  category         String?
  position         Int?
  preparedBeds     Int                  @default(1)
  laundryTemplate  Json?
  maintenanceTasks MaintenanceTask[]
  periodicTasks    PeriodicTask[]
  periodicTaskExecutions PeriodicTaskExecution[]
  reservations     Reservation[]
  stay             Stay?                @relation(fields: [stayId], references: [id])
  profiles         ConsumptionProfile[]
  events           ConsumptionEvent[] 
  productConsumptions ProductConsumption[]
  laundryDispatches LaundryDispatch[]

  @@unique([stayId, title])
}

model Guest {
  id           String        @id @default(uuid())
  name         String
  email        String?       @unique
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}

model Staff {
  id           String   @id @default(uuid())
  name         String
  role         String
  email        String   @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  passwordHash String
  phone        String?
  imageUrl     String?
  updatedAt    DateTime @updatedAt
  productConsumptions ProductConsumption[]
}

model CleaningStaff {
  id        String   @id @default(uuid())
  name      String
  status    String
  createdAt DateTime @default(now())
}

model Maintenance {
  id          String   @id @default(uuid())
  description String
  status      String
  createdAt   DateTime @default(now())
}

model Reservation {
  id           String   @id @default(uuid())
  roomId       String
  checkinDate  DateTime
  checkoutDate DateTime
  guestId      String
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  notes        String?
  cleaningDateOverride DateTime?
  cleaningChangeReason String?
  guest        Guest    @relation(fields: [guestId], references: [id])
  room         Room     @relation(fields: [roomId], references: [id])
  cleaningTasks Task[]
  productConsumptions ProductConsumption[]
  laundryDispatches LaundryDispatch[]
  assistedCheckin AssistedCheckin?
}

model AssistedCheckin {
  id                    String      @id @default(uuid())
  reservationId         String      @unique
  scheduledArrivalAt    DateTime?
  rulesMessageText      String?
  rulesMessageSentAt    DateTime?
  documentsReceivedAt   DateTime?
  keyDeliveryConfirmedAt DateTime?
  maintenanceTaskId     String?     @unique
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  reservation           Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  maintenanceTask       MaintenanceTask? @relation(fields: [maintenanceTaskId], references: [id], onDelete: SetNull)

  @@index([scheduledArrivalAt])
}

model Maid {
  name      String
  bank      String
  createdAt DateTime @default(now())
  pixKey    String
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  available String[]
  tasks     Task[]
  periodicTaskExecutions PeriodicTaskExecution[]
  productConsumptions ProductConsumption[]
  laundryDispatches LaundryDispatch[]
}

model Task {
  id                String       @id @default(uuid())
  date              DateTime
  stay              String
  rooms             String
  kind              String       @default("CHECKOUT")
  reservationId     String?
  recurrenceWeekday Int?
  notes             String?
  maidId            Int?
  maid              Maid?        @relation(fields: [maidId], references: [id])
  reservation       Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([kind, date])
  @@index([reservationId])
}

model PeriodicTask {
  id                  String                  @id @default(uuid())
  name                String
  description         String?
  frequency           PeriodicTaskFrequency
  customIntervalDays  Int?
  lastExecutionDate   DateTime?
  nextExecutionDate   DateTime
  active              Boolean                 @default(true)
  roomId              String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  room                Room                    @relation(fields: [roomId], references: [id])
  executions          PeriodicTaskExecution[]

  @@index([active, nextExecutionDate])
  @@index([roomId])
}

model PeriodicTaskExecution {
  id              String                      @id @default(uuid())
  taskId          String
  roomId          String
  assignedToId    Int?
  executionDate   DateTime
  status          PeriodicTaskExecutionStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  task            PeriodicTask                @relation(fields: [taskId], references: [id])
  room            Room                        @relation(fields: [roomId], references: [id])
  assignedTo      Maid?                       @relation(fields: [assignedToId], references: [id])

  @@unique([taskId, roomId, executionDate])
  @@index([executionDate])
  @@index([assignedToId])
}

model OperationalReminder {
  id          String   @id @default(uuid())
  stayId      String
  title       String
  message     String
  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stay        Stay     @relation(fields: [stayId], references: [id])

  @@index([stayId, active])
  @@index([startsAt, endsAt])
}

model PaymentStatus {
  id     String       @id @default(cuid())
  maidId String
  date   DateTime
  status PaymentState @default(PENDENTE)

  @@unique([maidId, date])
}

model MaintenanceTask {
  id          String            @id @default(uuid())
  code        String            @unique
  title       String
  description String?
  stayId      String?
  roomId      String?
  responsible String?
  collaboratorId String?
  status      String            @default("pendente")
  type        String?
  dueDate     DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isRecurring Boolean           @default(false)
  parentId    String?
  recurrence  Json?
  timezone    String?           @default("America/Sao_Paulo")
  parent      MaintenanceTask?  @relation("RecurringParent", fields: [parentId], references: [id])
  children    MaintenanceTask[] @relation("RecurringParent")
  room        Room?             @relation(fields: [roomId], references: [id])
  stay        Stay?             @relation(fields: [stayId], references: [id])
  collaborator MaintenanceCollaborator? @relation(fields: [collaboratorId], references: [id], onDelete: SetNull)
  assistedCheckin AssistedCheckin?

  @@unique([parentId, dueDate], map: "uniq_parent_dueDate")
  @@index([parentId])
  @@index([collaboratorId])
}

model MaintenanceCollaborator {
  id          String   @id @default(uuid())
  name        String
  birthDate   DateTime?
  cpf         String?
  pixKey      String?
  bankName    String?
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       MaintenanceTask[]

  @@index([active])
  @@index([name])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  category         String
  unitBase         UnitBase
  packageSizeValue Int?
  packageSizeUnit  String?
  defaultPrice     Decimal?
  active           Boolean  @default(true)
  sku              String?
  supplier         String?
  packageBaseQuantity Float?
  unitsPerPackage  Float?
  usageUnit        String?
  corridorWeight   Float?   @default(1)
  minimumStock     Float?
  targetStock      Float?
  reorderPoint     Float?
  shelfLifeDays    Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  consumptionProfiles       ConsumptionProfile[]
  inventories               Inventory[]
  purchases                 Purchase[]
  consumptionEvents         ConsumptionEvent[]
  dailyCommon      DailyCommonConsumptionLog[]
  entries          ProductEntry[]
  lots             ProductLot[]
  operationalConsumptions ProductConsumption[]
  alerts           ProductAlert[]
  predictions      ProductPrediction[]
  inventorySnapshots ProductInventorySnapshot[]
  usageCycles      ProductUsageCycle[]

  @@unique([name, category])
  @@index([active])
  @@index([category])
}

model ConsumptionProfile {
  id                     String  @id @default(cuid())
  stayId                 String
  roomId                 String?
  productId              String
  consumptionPerCleaning Int
  appliesToCommonAreas   Boolean @default(false)

  stay    Stay    @relation(fields: [stayId], references: [id])
  room    Room?   @relation(fields: [roomId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([stayId, roomId, productId])
  @@index([appliesToCommonAreas])
}

model Inventory {
  id        String @id @default(cuid())
  stayId    String
  productId String
  quantity  Float    @default(0)
  capacity  Float    @default(0)

  stay    Stay    @relation(fields: [stayId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([stayId, productId])
  @@index([stayId])
  @@index([productId])
}

model Purchase {
  id           String   @id @default(cuid())
  stayId       String
  productId    String
  quantity     Float
  unitPrice    Float
  purchaseDate DateTime @default(now())
  notes        String?

  stay    Stay    @relation(fields: [stayId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([purchaseDate])
}

model ConsumptionEvent {
  id            String   @id @default(cuid())
  stayId        String
  roomId        String?
  productId     String
  quantity      Int
  occurredAt    DateTime @default(now())
  reason        String
  reservationId String?

  stay    Stay    @relation(fields: [stayId], references: [id])
  room    Room?   @relation(fields: [roomId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([occurredAt])
  @@index([reservationId])
}

model DailyCommonConsumptionLog {
  id        String   @id @default(cuid())
  stayId    String
  productId String
  date      DateTime
  quantity  Int
  createdAt DateTime @default(now())

  stay    Stay    @relation(fields: [stayId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([stayId, productId, date])
  @@index([date])
}

model ProductEntry {
  id            String   @id @default(cuid())
  stayId        String
  productId     String
  lotId         String?
  quantity      Float
  unit          String
  baseQuantity  Float
  supplier      String?
  totalCost     Float?
  unitCost      Float?
  entryDate     DateTime @default(now())
  expiresAt     DateTime?
  invoiceNumber String?
  notes         String?
  createdAt     DateTime @default(now())

  stay    Stay       @relation(fields: [stayId], references: [id])
  product Product    @relation(fields: [productId], references: [id])
  lot     ProductLot? @relation(fields: [lotId], references: [id])

  @@index([stayId, entryDate])
  @@index([productId])
  @@index([expiresAt])
}

model ProductLot {
  id              String           @id @default(cuid())
  stayId          String
  productId       String
  code            String?
  initialQuantity Float
  remainingQuantity Float
  openedQuantity Float?
  status          ProductLotStatus @default(SEALED)
  openedAt        DateTime?
  depletedAt      DateTime?
  expiresAt       DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  stay         Stay                 @relation(fields: [stayId], references: [id])
  product      Product              @relation(fields: [productId], references: [id])
  entries      ProductEntry[]
  consumptions ProductConsumption[]
  usageCycles  ProductUsageCycle[]

  @@index([stayId, productId, status])
  @@index([expiresAt])
}

model ProductUsageCycle {
  id              String   @id @default(cuid())
  stayId          String
  productId       String
  lotId           String?
  startedAt       DateTime
  endedAt         DateTime
  consumedQuantity Float
  checkoutCount   Int
  corridorDays    Int
  weightedOperations Float
  avgPerCheckout  Float?
  avgPerCorridorDay Float?
  avgPerWeightedOperation Float?
  costPerCheckout Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stay    Stay        @relation(fields: [stayId], references: [id])
  product Product     @relation(fields: [productId], references: [id])
  lot     ProductLot? @relation(fields: [lotId], references: [id])

  @@index([stayId, startedAt, endedAt])
  @@index([productId])
  @@index([lotId])
}

model ProductConsumption {
  id             String               @id @default(cuid())
  stayId         String
  productId      String
  lotId          String?
  roomId         String?
  reservationId  String?
  staffId        String?
  maidId         Int?
  operationType  ProductOperationType
  location       String?
  quantity       Float
  unit           String
  baseQuantity   Float
  occurredAt     DateTime             @default(now())
  expectedQuantity Float?
  anomalyScore   Float?
  anomalyReason  String?
  notes          String?
  createdAt      DateTime             @default(now())

  stay        Stay         @relation(fields: [stayId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  lot         ProductLot?   @relation(fields: [lotId], references: [id])
  room        Room?        @relation(fields: [roomId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  staff       Staff?       @relation(fields: [staffId], references: [id])
  maid        Maid?        @relation(fields: [maidId], references: [id])

  @@index([stayId, occurredAt])
  @@index([productId, occurredAt])
  @@index([operationType])
  @@index([staffId])
  @@index([maidId])
  @@index([roomId])
  @@index([reservationId])
}

model ProductAlert {
  id          String        @id @default(cuid())
  stayId      String?
  productId   String?
  type        ProductAlertType
  severity    ProductAlertSeverity @default(INFO)
  title       String
  message     String
  metric      Float?
  baseline    Float?
  status      String        @default("open")
  metadata    Json?
  detectedAt  DateTime      @default(now())
  resolvedAt  DateTime?

  stay    Stay?    @relation(fields: [stayId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([status, severity])
  @@index([detectedAt])
  @@index([productId])
}

model ProductPrediction {
  id                  String   @id @default(cuid())
  stayId              String
  productId           String
  calculatedAt        DateTime @default(now())
  horizonDays         Int      @default(30)
  dailyAverage        Float
  projectedDemand     Float
  currentStock        Float
  daysRemaining       Float?
  reorderDate         DateTime?
  recommendedQuantity Float?
  confidence          Float?
  metadata            Json?

  stay    Stay    @relation(fields: [stayId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([stayId, calculatedAt])
  @@index([productId])
}

model ProductInventorySnapshot {
  id          String   @id @default(cuid())
  stayId      String
  productId   String
  quantity    Float
  capacity    Float?
  snapshotAt  DateTime @default(now())
  source      String   @default("system")
  notes       String?

  stay    Stay    @relation(fields: [stayId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([stayId, snapshotAt])
  @@index([productId])
}

model LaundryDispatch {
  id            String   @id @default(cuid())
  stayId        String
  roomId        String?
  reservationId String?
  maidId        Int?
  dispatchDate  DateTime @default(now())
  expectedSets  Int      @default(2)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stay        Stay         @relation(fields: [stayId], references: [id])
  room        Room?        @relation(fields: [roomId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  maid        Maid?        @relation(fields: [maidId], references: [id])
  items       LaundryDispatchItem[]

  @@index([stayId, dispatchDate])
  @@index([roomId])
  @@index([reservationId])
}

model LaundryDispatchItem {
  id         String          @id @default(cuid())
  dispatchId String
  itemType   LaundryItemType
  quantity   Int
  unitPieces Int
  notes      String?

  dispatch LaundryDispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@unique([dispatchId, itemType])
}

model LaundryItemPrice {
  id        String          @id @default(cuid())
  itemType  LaundryItemType @unique
  price     Decimal         @default(0)
  notes     String?
  updatedAt DateTime        @updatedAt
  createdAt DateTime        @default(now())
}

enum ProductOperationType {
  CHECKOUT_CLEANING
  DAILY_CLEANING
  DEEP_CLEANING
  COMMON_AREA
  LAUNDRY
  MAINTENANCE
  WASTE
  ADJUSTMENT
  OTHER
}

enum ProductLotStatus {
  SEALED
  OPEN
  DEPLETED
  EXPIRED
  DISCARDED
}

enum ProductAlertType {
  HIGH_CONSUMPTION
  LOW_STOCK
  STAFF_OUTLIER
  LAUNDRY_SPIKE
  STALE_PRODUCT
  EXPIRING_PRODUCT
  NEGATIVE_STOCK
  REORDER_SUGGESTION
}

enum ProductAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum LaundryItemType {
  FITTED_SHEET
  TOP_SHEET
  PILLOWCASE
  SHEET_SET
  PILLOWCASE_SET
  BLANKET
  COMFORTER
  BEDSPREAD
  FACE_TOWEL
  BATH_TOWEL
  RUG
}

enum PaymentState {
  PENDENTE
  PAGO
}

enum PeriodicTaskFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
  CUSTOM_DAYS
}

enum PeriodicTaskExecutionStatus {
  SCHEDULED
  COMPLETED
  SKIPPED
  CANCELLED
}
